---
// Custom cursor — hidden on touch devices, activates on first mousemove
---

<div class="cursor" aria-hidden="true">
  <div class="cursor-dot" data-cursor-dot></div>
  <div class="cursor-ring" data-cursor-ring></div>
</div>

<style>
  .cursor {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9999;
  }

  .cursor-dot {
    position: fixed;
    top: -3px;
    left: -3px;
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    border-radius: 50%;
    will-change: transform;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .cursor-ring {
    position: fixed;
    top: -14px;
    left: -14px;
    width: 28px;
    height: 28px;
    border: 1.5px solid var(--color-text-muted);
    border-radius: 50%;
    will-change: transform;
    opacity: 0;
    transition:
      width 0.22s ease,
      height 0.22s ease,
      top 0.22s ease,
      left 0.22s ease,
      opacity 0.3s ease,
      border-color 0.22s ease;
  }

  :global(.has-cursor) .cursor-dot,
  :global(.has-cursor) .cursor-ring {
    opacity: 1;
  }

  :global(.has-cursor.cursor-hover) .cursor-ring {
    width: 44px;
    height: 44px;
    top: -22px;
    left: -22px;
    border-color: var(--color-accent);
    opacity: 0.85;
  }

  :global(.has-cursor) {
    cursor: none;
  }

  :global(.has-cursor) * {
    cursor: none !important;
  }

  /* Never show on touch */
  @media (hover: none) {
    .cursor {
      display: none;
    }
  }
</style>

<script>
  import '../scripts/cursor';
</script>
