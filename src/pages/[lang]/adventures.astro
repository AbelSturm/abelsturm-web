---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import AdventureCard from '../../components/AdventureCard.astro';
import { t, SUPPORTED_LOCALES, type Lang, type UiKey } from '../../i18n/ui';

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = (Astro.params.lang ?? 'es') as Lang;

type Category = 'climbing' | 'motorcycle' | 'mountains';

const allAdventures = await getCollection('adventures');
const sorted = allAdventures.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories: Category[] = ['climbing', 'motorcycle', 'mountains'];

const categoryKeyMap: Record<Category, UiKey> = {
  climbing: 'adventures.cat.climbing',
  motorcycle: 'adventures.cat.motorcycle',
  mountains: 'adventures.cat.mountains',
};
---

<BaseLayout
  title={`${t(lang, 'adventures.title')} — Abel Sturm`}
  description={t(lang, 'adventures.subtitle')}
  lang={lang}
>
  <Nav lang={lang} />

  <main class="max-w-5xl mx-auto px-5 py-14 sm:py-20">
    <div data-reveal class="mb-16">
      <h1 class="text-[clamp(2.5rem,7vw,5rem)] leading-[0.95] tracking-[-0.04em] mb-3">
        {t(lang, 'adventures.title')}
      </h1>
      <p class="text-base font-light text-[var(--color-text-muted)]">{t(lang, 'adventures.subtitle')}</p>
    </div>

    {categories.map((category) => {
      const items = sorted.filter((a) => a.data.category === category);
      if (items.length === 0) return null;
      return (
        <section class="mb-16">
          <h2
            data-reveal
            class="text-xs font-semibold uppercase tracking-[0.15em] text-[var(--color-text-muted)] mb-8 pb-3 border-b border-[var(--color-border)]"
            style="font-family: 'Inter', system-ui, sans-serif; letter-spacing: 0.15em;"
          >
            {t(lang, categoryKeyMap[category])}
          </h2>
          <div class="grid gap-5 sm:grid-cols-2">
            {items.map((adventure, i) => (
              <div data-reveal data-reveal-delay={i * 100}>
                <AdventureCard
                  title={adventure.data.title}
                  category={adventure.data.category}
                  date={adventure.data.date}
                  description={adventure.data.description}
                  lang={lang}
                />
              </div>
            ))}
          </div>
        </section>
      );
    })}
  </main>
</BaseLayout>
