---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import AdventureCard from '../../components/AdventureCard.astro';
import { t, SUPPORTED_LOCALES, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = (Astro.params.lang ?? 'es') as Lang;

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 3);

const allAdventures = await getCollection('adventures');
const featuredAdventures = allAdventures
  .filter((a) => a.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);
---

<BaseLayout
  title="Abel Sturm"
  description={t(lang, 'home.subtitle')}
  lang={lang}
>
  <Nav lang={lang} />

  <!-- Hero -->
  <section class="relative min-h-[60vh] flex flex-col justify-end overflow-hidden px-5 pb-16 sm:pb-24 max-w-5xl mx-auto w-full">
    <div class="hero-bg" data-parallax></div>
    <div class="relative z-10 pt-24">
      <h1
        data-reveal
        class="text-[clamp(3.5rem,10vw,7.5rem)] leading-[0.92] tracking-[-0.04em] mb-6"
        transition:name="hero-title"
      >
        Abel Sturm
      </h1>
      <p
        data-reveal
        data-reveal-delay="90"
        class="text-lg sm:text-xl italic font-light text-[var(--color-text-muted)] mb-2 max-w-xl"
      >
        {t(lang, 'home.tagline')}
      </p>
      <p
        data-reveal
        data-reveal-delay="160"
        class="text-base text-[var(--color-text-muted)] font-light"
      >
        {t(lang, 'home.subtitle')}
      </p>
    </div>
  </section>

  <main class="max-w-5xl mx-auto px-5 pb-20 sm:pb-28">
    <!-- Featured Projects -->
    <section class="mb-20">
      <div data-reveal class="flex items-baseline justify-between mb-8">
        <h2 class="text-2xl">{t(lang, 'home.featured_projects')}</h2>
        <a href={`/${lang}/projects`} class="text-sm text-[var(--color-accent)] hover:underline shrink-0">
          {t(lang, 'home.see_all_projects')}
        </a>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {featuredProjects.map((project, i) => (
          <div data-reveal data-reveal-delay={i * 80}>
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              stack={project.data.stack}
              category={project.data.category}
              status={project.data.status}
              github={project.data.github}
              live={project.data.live}
              lang={lang}
            />
          </div>
        ))}
      </div>
    </section>

    <!-- Featured Adventures -->
    <section>
      <div data-reveal class="flex items-baseline justify-between mb-8">
        <h2 class="text-2xl">{t(lang, 'home.featured_adventures')}</h2>
        <a href={`/${lang}/adventures`} class="text-sm text-[var(--color-accent)] hover:underline shrink-0">
          {t(lang, 'home.see_all_adventures')}
        </a>
      </div>
      <div class="grid gap-5 sm:grid-cols-2">
        {featuredAdventures.map((adventure, i) => (
          <div data-reveal data-reveal-delay={i * 100}>
            <AdventureCard
              title={adventure.data.title}
              category={adventure.data.category}
              date={adventure.data.date}
              description={adventure.data.description}
              lang={lang}
            />
          </div>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
