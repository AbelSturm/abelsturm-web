---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import AdventureCard from '../../components/AdventureCard.astro';
import { t, SUPPORTED_LOCALES, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = (Astro.params.lang ?? 'es') as Lang;

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 3);

const allAdventures = await getCollection('adventures');
const featuredAdventures = allAdventures
  .filter((a) => a.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);
---

<BaseLayout
  title="Abel Sturm"
  description={t(lang, 'home.subtitle')}
  lang={lang}
>
  <Nav lang={lang} />

  <main class="max-w-4xl mx-auto px-4 py-16 sm:py-24">
    <!-- Hero -->
    <section class="mb-20 sm:mb-28">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-4">Abel Sturm</h1>
      <p class="text-lg sm:text-xl italic text-[var(--color-text-muted)] mb-2">
        {t(lang, 'home.tagline')}
      </p>
      <p class="text-base text-[var(--color-text-muted)]">
        {t(lang, 'home.subtitle')}
      </p>
    </section>

    <!-- Featured Projects -->
    <section class="mb-16">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-xl font-semibold">{t(lang, 'home.featured_projects')}</h2>
        <a
          href={`/${lang}/projects`}
          class="text-sm text-[var(--color-accent)] hover:underline"
        >
          {t(lang, 'home.see_all_projects')}
        </a>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {featuredProjects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            stack={project.data.stack}
            category={project.data.category}
            status={project.data.status}
            github={project.data.github}
            live={project.data.live}
            lang={lang}
          />
        ))}
      </div>
    </section>

    <!-- Featured Adventures -->
    <section>
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-xl font-semibold">{t(lang, 'home.featured_adventures')}</h2>
        <a
          href={`/${lang}/adventures`}
          class="text-sm text-[var(--color-accent)] hover:underline"
        >
          {t(lang, 'home.see_all_adventures')}
        </a>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {featuredAdventures.map((adventure) => (
          <AdventureCard
            title={adventure.data.title}
            category={adventure.data.category}
            date={adventure.data.date}
            description={adventure.data.description}
            lang={lang}
          />
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
