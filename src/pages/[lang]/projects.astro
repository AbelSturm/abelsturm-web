---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { t, SUPPORTED_LOCALES, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = (Astro.params.lang ?? 'es') as Lang;

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const personalProjects = sorted.filter((p) => p.data.category === 'personal');
const workProjects = sorted.filter((p) => p.data.category === 'work');
---

<BaseLayout
  title={`${t(lang, 'projects.title')} — Abel Sturm`}
  description={t(lang, 'home.subtitle')}
  lang={lang}
>
  <Nav lang={lang} />

  <main class="max-w-5xl mx-auto px-5 py-14 sm:py-20">
    <h1
      data-reveal
      class="text-[clamp(2.5rem,7vw,5rem)] leading-[0.95] tracking-[-0.04em] mb-16"
    >
      {t(lang, 'projects.title')}
    </h1>

    <!-- Personal -->
    <section class="mb-16">
      <h2
        data-reveal
        class="text-xs font-semibold uppercase tracking-[0.15em] text-[var(--color-text-muted)] mb-8 pb-3 border-b border-[var(--color-border)]"
        style="font-family: 'Inter', system-ui, sans-serif; letter-spacing: 0.15em;"
      >
        {t(lang, 'projects.personal')}
      </h2>
      <div class="grid gap-5 sm:grid-cols-2">
        {personalProjects.map((project, i) => (
          <div data-reveal data-reveal-delay={i * 80}>
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              stack={project.data.stack}
              category={project.data.category}
              status={project.data.status}
              github={project.data.github}
              live={project.data.live}
              lang={lang}
            />
          </div>
        ))}
      </div>
    </section>

    <!-- Work -->
    <section>
      <h2
        data-reveal
        class="text-xs font-semibold uppercase tracking-[0.15em] text-[var(--color-text-muted)] mb-8 pb-3 border-b border-[var(--color-border)]"
        style="font-family: 'Inter', system-ui, sans-serif; letter-spacing: 0.15em;"
      >
        {t(lang, 'projects.work')}
      </h2>
      <div class="grid gap-5 sm:grid-cols-2">
        {workProjects.map((project, i) => (
          <div data-reveal data-reveal-delay={i * 80}>
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              stack={project.data.stack}
              category={project.data.category}
              status={project.data.status}
              github={project.data.github}
              live={project.data.live}
              lang={lang}
            />
          </div>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
